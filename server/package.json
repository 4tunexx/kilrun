{
  "name": "kilrun-game-server",
  "version": "0.1.0",
  "private": true,
  "description": "Authoritative real-time multiplayer server for Kilrun (Deathrun / Horde / Competitive) built on Colyseus.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/monitor": "0.16.7",
    "@colyseus/schema": "3.0.76",
    "@colyseus/ws-transport": "0.16.5",
    "colyseus": "0.16.5",
    "cors": "^2.8.5",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "tsx": "4.23.1",
    "typescript": "^5"
  }
}
