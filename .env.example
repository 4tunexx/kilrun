# Copy this file to `.env` and fill in real values. Never commit `.env`.

# MongoDB Atlas connection string (Prisma).
# Required query params for Vercel serverless:
#   - maxPoolSize=1  (many warm instances; keep each pool tiny)
#   - serverSelectionTimeoutMS=5000
# Also in Atlas UI: Network Access -> allow 0.0.0.0/0 (Vercel has dynamic IPs),
# and confirm the cluster is not paused.
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kilrun?retryWrites=true&w=majority&appName=Cluster0&maxPoolSize=1&serverSelectionTimeoutMS=5000"

# Steam Web API key (https://steamcommunity.com/dev/apikey) - used to enrich
# player profiles (username/avatar) after the OpenID handshake succeeds.
STEAM_API_KEY=

# NextAuth / Auth.js session configuration
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Clerk - used ONLY for the secondary "Arcade Verification Key" email-OTP
# widget layered on top of an existing Steam login. Steam remains the sole
# real authentication system; fill these in from your Clerk Dashboard
# (dashboard.clerk.com -> your app -> API Keys / Webhooks).
# In "User & Authentication" settings, enable "Email verification code" and
# disable Password so signUp.create() only asks for an email address.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Realtime game server (Colyseus, deployed separately from this Next.js app --
# see /server/README.md). Locally this defaults to ws://localhost:2567 if unset.
NEXT_PUBLIC_GAME_SERVER_URL=ws://localhost:2567

# Optional -- only needed if you use the Gemini-powered features.
GEMINI_API_KEY=

# Comma-separated Steam IDs that are promoted to admin on every Steam login.
# Owner 76561198001993310 is always admin in code; add more here if needed.
ADMIN_STEAM_IDS=76561198001993310
