generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // Vercel serverless runs Amazon Linux (rhel) with OpenSSL 3.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// Account privilege: player | vip | moderator | admin
model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  steamId     String   @unique
  username    String
  avatarUrl   String
  vpCurrency  Int      @default(0)
  xpProgress  Int      @default(0)
  /// Killrun Points — competitive Elo-style rating (Faceit / ESEA style).
  /// Profile `currentRank` is derived from KP via getRankForKp().
  kp          Int      @default(1000)
  currentRank String   @default("Unranked")
  role        String   @default("player")
  bio         String   @default("")
  /// ISO 3166-1 alpha-2 country code (e.g. "us", "gb") for public flag.
  countryCode String   @default("")
  notifyPush  Boolean  @default(true)
  notifyEmail Boolean  @default(true)
  isBanned    Boolean  @default(false)
  isVip       Boolean  @default(false)
  /// When Premium / Ranked access expires (null + isVip = legacy permanent VIP).
  premiumExpiresAt DateTime?
  isMuted     Boolean  @default(false)
  createdAt   DateTime @default(now())

  clerkId       String?  @unique
  email         String?  @unique
  emailVerified Boolean  @default(false)

  /// Net community reputation (+rep / -rep from other players).
  reputation Int @default(0)

  /// Consecutive-day login streak, used for "daily login" style requirements.
  loginStreak  Int       @default(0)
  lastLoginAt  DateTime?
  /// Last hub presence heartbeat (online = seen within ~2 minutes).
  lastSeenAt   DateTime?
  /// Last time the player opened the hub leaderboard (daily mission).
  lastLeaderboardAt DateTime?

  /// Lifetime cosmetics actions for achievement / mission metrics.
  cosmeticEquipCount  Int @default(0)
  cosmeticDeleteCount Int @default(0)
  cosmeticResellCount Int @default(0)

  /// Denormalized snapshot of the equipped profile banner cosmetic, copied
  /// from the owned InventoryItem at equip time so rendering the profile
  /// header never needs an extra lookup.
  equippedBannerItemName  String?
  equippedBannerImageUrl  String?
  equippedBannerConfig    Json?

  /// Equipped avatar frame cosmetic (style/color JSON snapshot).
  equippedFrameItemName String?
  equippedFrameConfig   Json?

  /// Equipped nickname effect cosmetic (effect style JSON snapshot).
  equippedNicknameItemName String?
  equippedNicknameConfig   Json?

  /// Equipped body skins from Model Editor (Record<slot, skinConfig>).
  equippedSkins Json?

  /// Optional display status line shown on public profile.
  statusMessage String @default("")

  /// Profile "showcase" slots + layout for the mini hover-card. Stored as
  /// either a legacy JSON array of { slot, itemType, refId }, or
  /// { entries: [...], layout: { position, align } }.
  showcaseItems Json?

  matchStats         MatchStat[]
  activeMissions     ActiveMission[]
  matchResults       MatchResult[]
  sentMessages       Message[]       @relation("SentMessages")
  receivedMessages   Message[]       @relation("ReceivedMessages")
  forumPosts         ForumPost[]
  forumReplies       ForumReply[]
  supportTickets     SupportTicket[]
  notifications      Notification[]
  friendshipsA       Friendship[]    @relation("FriendshipA")
  friendshipsB       Friendship[]    @relation("FriendshipB")
  purchases          Purchase[]
  userAchievements   UserAchievement[]
  userBadges         UserBadge[]
  globalChatMessages GlobalChatMessage[]
  inventoryItems     InventoryItem[]
  reputationGiven    ReputationVote[] @relation("ReputationVotesGiven")
  reputationReceived ReputationVote[] @relation("ReputationVotesReceived")
}

model MatchStat {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  score          Int
  distance       Int
  livesRemaining Int
  datePlayed     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model MatchResult {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  mode     String
  role     String?
  outcome  String
  xpEarned Int
  vpEarned Int
  /// Competitive KP delta applied for this match (can be negative).
  kpDelta  Int      @default(0)
  /// Extra mode stats (waves cleared, kills, rounds won, …) as JSON.
  stats    Json?
  playedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, mode])
}

model StoreItem {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  itemName     String
  itemCategory String
  itemSku      String  @unique
  vpPrice      Int
  imageUrl     String?
  isAvailable  Boolean @default(true)

  /// Which equip slot this cosmetic occupies: banner | frame | nickname | skin_*.
  /// Null for non-equippable items (boosts, emotes, consumables, ...).
  cosmeticSlot String?
  /// Generated banner config (colors, gradient angle, animation style).
  bannerConfig Json?
  /// Frame / nickname / player skin config JSON (see src/lib/cosmetics.ts, player-skins.ts).
  cosmeticConfig Json?

  /// Times purchased — used for "Popular" sort.
  purchaseCount Int @default(0)
  /// Fire sale discount 0–90. 0 = not on sale.
  fireSalePercent Int @default(0)
  /// When the fire sale ends (UTC). Ignored if percent is 0.
  fireSaleEndsAt  DateTime?
  createdAt DateTime @default(now())
}

model MissionTemplate {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  key         String  @unique
  title       String
  description String
  rewardXp    Int
  targetCount Int
  /// Progression metric key (see requirement-types.ts).
  metric      String
  /// game | website | daily
  category    String  @default("game")
  isActive    Boolean @default(true)
  /// Optional custom icon image uploaded/set in the admin panel.
  iconImageUrl String?
}

model ActiveMission {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  userId       String  @db.ObjectId
  templateKey  String  @default("")
  title        String
  description  String
  rewardXp     Int
  targetCount  Int
  currentCount Int     @default(0)
  metric       String  @default("runs")
  /// Copied from MissionTemplate: game | website | daily
  category     String  @default("game")
  /// YYYY-MM-DD for daily missions (resets each calendar day). Empty for main.
  periodKey    String  @default("")
  isCompleted  Boolean @default(false)
  iconImageUrl String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, metric])
  @@index([userId, category, periodKey])
}

model AchievementDefinition {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  key         String  @unique
  title       String
  description String
  /// game | website
  category    String  @default("game")
  metric      String
  targetCount Int     @default(1)
  xpReward    Int     @default(50)
  icon        String  @default("trophy")
  /// Optional custom icon image uploaded in the admin panel (overrides `icon`).
  iconImageUrl String?
  isActive    Boolean @default(true)

  unlocks UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  achievementId String   @db.ObjectId
  unlockedAt    DateTime @default(now())

  user        User                  @relation(fields: [userId], references: [id])
  achievement AchievementDefinition @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
}

model BadgeDefinition {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  key         String  @unique
  title       String
  description String
  rarity      String  @default("common")
  icon        String  @default("award")
  /// Optional custom icon image uploaded in the admin panel (overrides `icon`).
  iconImageUrl String?
  /// auto unlock metric or "manual" / "role"
  metric      String  @default("manual")
  targetCount Int     @default(1)
  isActive    Boolean @default(true)

  unlocks UserBadge[]
}

model UserBadge {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  badgeId  String   @db.ObjectId
  earnedAt DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id])
  badge BadgeDefinition @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
}

model SiteSettings {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  singletonKey       String  @unique @default("default")
  /// Small mark (sidebar / footer) — defaults to /K2.png when empty.
  logoUrl            String  @default("")
  /// Wordmark shown in home hero / landing — defaults to /kilrun.png when empty.
  headerLogoUrl      String  @default("")
  /// JSON: scale, offsetX, offsetY, opacity, effect for the header wordmark.
  headerLogoStyle    String  @default("{\"scale\":1,\"offsetX\":0,\"offsetY\":0,\"opacity\":1,\"effect\":\"none\"}")
  /// Full-page hub chrome background.
  backgroundUrl      String  @default("https://i.postimg.cc/tJgX2XgN/bg.png")
  /// Home hero banner image (parallax).
  homeHeroImage      String  @default("")
  headerTitle        String  @default("Welcome to Kilrun")
  headerSubtitle     String  @default("The ultimate deathrun experience. Compete, conquer, and climb the ranks.")
  landingHeroImage   String  @default("")
  /// JSON array of { src, alt?, title? } for the landing hero carousel.
  landingHeroSlides  String  @default("[]")
  gameDisabled       Boolean @default(false)
  gameDisabledMsg    String  @default("Kilrun is temporarily offline for maintenance. Check back soon.")
  /// When set and in the future (with gameDisabled), show countdown / auto-enable after.
  gameDisabledUntil  DateTime?
  chatEnabled        Boolean @default(true)
  /// JSON: which hub pages are enabled for non-staff players.
  hubPagesJson       String  @default("{}")
  /// JSON: { left: HubPageId[], right: HubPageId[] } live nav placement.
  hubNavJson         String  @default("{}")
  /// JSON: { showHeader, showFooter, showLandingSlider }.
  hubChromeJson      String  @default("{}")
}

model GlobalChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  body      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model Friendship {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userAId   String   @db.ObjectId
  userBId   String   @db.ObjectId
  status    String   @default("pending")
  createdAt DateTime @default(now())

  userA User @relation("FriendshipA", fields: [userAId], references: [id])
  userB User @relation("FriendshipB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
  @@index([userBId])
}

model Message {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String    @db.ObjectId
  receiverId String    @db.ObjectId
  body       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
  @@index([receiverId, createdAt])
}

model ForumPost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  authorId  String   @db.ObjectId
  title     String
  body      String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author  User         @relation(fields: [authorId], references: [id])
  replies ForumReply[]

  @@index([createdAt])
}

model ForumReply {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String   @db.ObjectId
  authorId  String   @db.ObjectId
  body      String
  createdAt DateTime @default(now())

  post   ForumPost @relation(fields: [postId], references: [id])
  author User      @relation(fields: [authorId], references: [id])

  @@index([postId])
}

model SupportTicket {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  subject   String
  category  String
  body      String
  status    String   @default("open")
  staffNote String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  body      String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
}

model NewsPost {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  summary        String
  body           String
  /// Optional hero / header image for the news article.
  headerImageUrl String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model Guide {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  summary   String
  body      String
  category  String   @default("general")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Purchase {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  itemSku   String
  itemName  String
  vpSpent   Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

/// An owned copy of a store item, shown in the player's inventory drawer.
/// Snapshots cosmetic data at acquisition time so later admin edits to the
/// shop catalog don't retroactively change items players already own.
model InventoryItem {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  itemSku      String
  itemName     String
  itemCategory String
  cosmeticSlot String?
  bannerConfig Json?
  /// Frame / nickname effect config snapshot at purchase time.
  cosmeticConfig Json?
  imageUrl     String?
  /// Original VP price paid; resale refunds a fraction of this.
  vpValue      Int      @default(0)
  isEquipped   Boolean  @default(false)
  acquiredAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, cosmeticSlot])
}

/// Staff moderation / admin action trail.
model AuditLog {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId        String   @db.ObjectId
  actorUsername  String
  action         String
  targetUserId   String?
  targetUsername String?
  detail         String   @default("")
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
}

/// A single player's +1/-1 reputation vote on another player. Unique per
/// (voter, target) pair so a player can change their vote but not spam it.
model ReputationVote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  voterId   String   @db.ObjectId
  targetId  String   @db.ObjectId
  value     Int
  createdAt DateTime @default(now())

  voter  User @relation("ReputationVotesGiven", fields: [voterId], references: [id])
  target User @relation("ReputationVotesReceived", fields: [targetId], references: [id])

  @@unique([voterId, targetId])
  @@index([targetId])
}
